# Optional. The assistant works without this and falls back to rule-based summaries.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional email alerts. Keep real values in Kubernetes Secrets or local env only.
NOTIFICATIONS_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_STARTTLS=true
ALERT_EMAIL_TO=
ALERT_SEVERITIES=critical,warning
CPU_ALERT_THRESHOLD_PERCENT=80
PVC_ALERT_THRESHOLD_PERCENT=80
